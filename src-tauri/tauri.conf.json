{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kingdom RP Launcher",
  "mainBinaryName": "Kingdom RP Launcher",
  "version": "0.5.1",
  "identifier": "com.kingdomrp.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kingdom RP Launcher",
        "width": 920,
        "height": 760,
        "minWidth": 720,
        "minHeight": 660,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "data:", "blob:", "asset:", "http://asset.localhost"],
        "font-src": ["'self'", "data:"],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "ws://localhost:1421",
          "https://kingdom-rp.github.io",
          "https://github.com",
          "https://objects.githubusercontent.com",
          "https://*.mojang.com",
          "https://*.minecraft.net",
          "https://45.87.121.82.nip.io"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Kingdom RP",
    "copyright": "© Kingdom RP",
    "shortDescription": "Kingdom RP Launcher",
    "longDescription": "Лаунчер для Kingdom RP — Minecraft RPG-сервера в средневековом стиле.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Russian", "English"],
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGQTAwN0UxODMyQTE1NzcKUldSM0ZTcUQ0UWVnLzdlUWtPdzQ5WFFDd3crd2N5OTc3UXdvb2N1STdUTGRORXB4Ui9TR28xaVAK",
      "endpoints": [
        "https://github.com/Kingdom-RP/krp-launcher/releases/latest/download/latest.json"
      ]
    }
  }
}
